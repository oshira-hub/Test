if _G.a then return end
_G.a = true

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")
local CoreGui = game:GetService("CoreGui")
local LP = Players.LocalPlayer

local function Notify(Text, Duration)
    StarterGui:SetCore("SendNotification", {
        Title = "Sheriff Utilities",
        Text = Text,
        Duration = Duration
    })
end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "SheriffUtilities"
ScreenGui.Parent = CoreGui
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local function CreateButton(Name, Image, Position)
    local Btn = Instance.new("ImageButton")
    Btn.Name = Name
    Btn.Parent = ScreenGui
    Btn.BorderSizePixel = 0
    Btn.BackgroundTransparency = 0.2
    Btn.BackgroundColor3 = Color3.new(0, 0, 0)
    Btn.Image = Image
    Btn.Size = UDim2.new(0, 80, 0, 80)
    Btn.BorderColor3 = Color3.new(0, 0, 0)
    Btn.Position = Position

    local Corner = Instance.new("UICorner")
    Corner.CornerRadius = UDim.new(0, 100)
    Corner.Parent = Btn

    local Stroke = Instance.new("UIStroke")
    Stroke.Thickness = 2
    Stroke.Color = Color3.fromRGB(2, 154, 255)
    Stroke.Parent = Btn

    return Btn, Stroke
end

local function CenterPosition(YOffset)
    return UDim2.new(0.5, -40, 0, YOffset)
end

local ShootBtn, ShootStroke = CreateButton("ShootMurder", "rbxassetid://80542356257974", CenterPosition(100))
local ESPBtn, ESPStroke = CreateButton("ESP", "rbxassetid://97344643216039", CenterPosition(250))

local function MakeDraggable(Button)
    local Dragging, DragStart, StartPos
    Button.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = Input.Position
            StartPos = Button.Position
        end
    end)
    Button.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
            local Delta = Input.Position - DragStart
            Button.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
        end
    end)
end

MakeDraggable(ShootBtn)
MakeDraggable(ESPBtn)

Notify("Buttons are draggable!", 10)

local ESPEnabled = false
local Highlights = {}

local function FindMurderer()
    for _, Pl in ipairs(Players:GetPlayers()) do
        if Pl ~= LP then
            if Pl.Backpack:FindFirstChild("Knife") or (Pl.Character and Pl.Character:FindFirstChild("Knife")) then
                return Pl
            end
        end
    end
    return nil
end

local function FindSheriff()
    for _, Pl in ipairs(Players:GetPlayers()) do
        if Pl.Backpack:FindFirstChild("Gun") or (Pl.Character and Pl.Character:FindFirstChild("Gun")) then
            return Pl
        end
    end
    return nil
end

local function UpdateESP()
    local Sheriff = FindSheriff()
    local Murderer = FindMurderer()

    for _, Pl in ipairs(Players:GetPlayers()) do
        local Char = Pl.Character
        local H = Highlights[Pl]

        if Char and ESPEnabled and Pl ~= LP then
            if not H or H.Parent ~= Char then
                if H then H:Destroy() end
                H = Instance.new("Highlight")
                H.Name = "ESP_Highlight"
                H.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                H.FillTransparency = 0.3
                H.OutlineTransparency = 0
                H.Parent = Char
                Highlights[Pl] = H
            end

            if Pl == Murderer then
                H.FillColor = Color3.fromRGB(255, 0, 0)
                H.OutlineColor = Color3.fromRGB(255, 0, 0)
            elseif Pl == Sheriff then
                H.FillColor = Color3.fromRGB(0, 0, 255)
                H.OutlineColor = Color3.fromRGB(0, 0, 255)
            else
                if H then
                    H:Destroy()
                    Highlights[Pl] = nil
                end
            end
        else
            if H then
                H:Destroy()
                Highlights[Pl] = nil
            end
        end
    end
end

local function ToggleESP()
    ESPEnabled = not ESPEnabled
    ESPStroke.Color = ESPEnabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(2, 154, 255)
    UpdateESP()
    Notify(ESPEnabled and "ESP Enabled" or "ESP Disabled")
end

ESPBtn.MouseButton1Click:Connect(ToggleESP)

RunService.Heartbeat:Connect(UpdateESP)

Players.PlayerRemoving:Connect(function(Pl)
    if Highlights[Pl] then
        Highlights[Pl]:Destroy()
        Highlights[Pl] = nil
    end
end)

local function GetPredictedPosition(Player, Offset)
    local Ch = Player.Character
    if not Ch then return nil end
    local HRP = Ch:FindFirstChild("HumanoidRootPart")
    local Hum = Ch:FindFirstChildOfClass("Humanoid")
    if not HRP or not Hum then return nil end
    return HRP.Position + (HRP.AssemblyLinearVelocity * 0.15) + (Hum.MoveDirection * (Offset or 2.8))
end

local function ShootMurderer()
    if FindSheriff() ~= LP then
        Notify("You are not the Sheriff!")
        return
    end
    local Murderer = FindMurderer()
    if not Murderer then
        Notify("No murderer found!")
        return
    end
    local Char = LP.Character
    if not Char then return end

    if not Char:FindFirstChild("Gun") then
        local Gun = LP.Backpack:FindFirstChild("Gun")
        if Gun then
            local Hum = Char:FindFirstChildOfClass("Humanoid")
            if Hum then Hum:EquipTool(Gun) end
        else
            Notify("You don't have a gun!")
            return
        end
    end

    local Gun = Char:FindFirstChild("Gun")
    if not Gun then return end
    local MurdererHRP = Murderer.Character and Murderer.Character:FindFirstChild("HumanoidRootPart")
    if not MurdererHRP then return end

    local PredictedPos = GetPredictedPosition(Murderer, 2.8) or MurdererHRP.Position
    local Args = { CFrame.new(Char.RightHand.Position), CFrame.new(PredictedPos) }

    local ShootRemote = Gun:FindFirstChild("Shoot") or Gun:FindFirstChild("KnifeLocal")
    if ShootRemote then
        if ShootRemote:IsA("RemoteEvent") then
            ShootRemote:FireServer(unpack(Args))
        elseif ShootRemote:IsA("RemoteFunction") then
            ShootRemote:InvokeServer(unpack(Args))
        else
            local CreateBeam = Gun:FindFirstChild("KnifeLocal") and Gun.KnifeLocal:FindFirstChild("CreateBeam")
            if CreateBeam and CreateBeam:IsA("RemoteFunction") then
                CreateBeam:InvokeServer(1, PredictedPos, "AH2")
            end
        end
    end
end

ShootBtn.MouseButton1Click:Connect(ShootMurderer)

UpdateESP()
